# farfield — one environment file for the whole monorepo.
#
# Copy to .env and fill in. Every app reads the nearest .env walking up from
# its working directory, so this single file at the repo root serves them all.

# ── shared ──────────────────────────────────────────────────────────────
# Bind interface. 127.0.0.1 in dev; Docker sets 0.0.0.0 itself.
HOST=127.0.0.1
# true for HTTPS-only session cookies (production).
COOKIE_SECURE=false
# One password for every app's HTML admin UI.
PASSWORD=changeme
# Browser-facing service URLs — injected into the content/feed editors so the
# blob & series pickers can fetch directly. Public hostnames in production;
# localhost in dev.
BLOBS_PUBLIC_URL=http://127.0.0.1:8789
CONTENT_PUBLIC_URL=http://127.0.0.1:8787

# ── keys ────────────────────────────────────────────────────────────────
KEYS_PORT=8801
# SQLite — the shared admin-issued key store + the keys app's own sessions.
# Every keyed app that sets KEYS_DB_PATH honors keys minted there alongside
# its env keys; unset, an app runs env-keys-only. Production points every app
# at the same /data/keys.sqlite.
KEYS_DB_PATH=data/keys.sqlite

# ── blobs ───────────────────────────────────────────────────────────────
BLOBS_PORT=8789
# SQLite — blob metadata index + admin sessions.
BLOBS_DB_PATH=data/blobs.sqlite
# API key for the blobs JSON write endpoints. Empty disables writes.
# Also required by the backup app to store snapshots — set a real value.
BLOBS_API_KEY=
# Optional read token: set to gate the enumerating read endpoints.
BLOBS_READ_KEY=
# URL other farfield apps use to reach the blobs service.
BLOBS_URL=http://127.0.0.1:8789
# Byte store backend: "local" (a directory) or "r2" (Cloudflare R2).
BLOBS_BACKEND=local
# Local backend directory (when BLOBS_BACKEND=local).
BLOBS_DIR=data/blobs
# R2 backend credentials (when BLOBS_BACKEND=r2). Shared by every R2-backed
# app (blobs, library).
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── library ─────────────────────────────────────────────────────────────
LIBRARY_PORT=8797
# SQLite — book metadata index + admin sessions.
LIBRARY_DB_PATH=data/library.sqlite
# One credential for the whole API surface: the HTTP Basic password OPDS
# readers send for the catalog, and the X-API-Key for the upload API. Empty
# disables both the catalog (for readers) and uploads.
LIBRARY_API_KEY=
# Optional narrower upload-only credential (add/organize books; no delete, no
# catalog reads) — for handing to a helper agent.
LIBRARY_UPLOAD_KEY=
# Per-file upload cap in MiB (default 100).
LIBRARY_MAX_UPLOAD=
# Staging directory for resumable (tus) uploads.
LIBRARY_TUS_DIR=data/tus-staging
# Byte store backend: "local" (a directory) or "r2" (Cloudflare R2).
LIBRARY_BACKEND=local
# Local backend directory (when LIBRARY_BACKEND=local). EPUBs + covers, by CID.
LIBRARY_DIR=data/library

# ── content ─────────────────────────────────────────────────────────────
CONTENT_PORT=8787
# SQLite — collections, entries, and admin sessions.
CONTENT_DB_PATH=data/content.sqlite
# API key for the content JSON write endpoints. Empty disables writes.
CONTENT_API_KEY=
# Optional read token: set to gate the enumerating read endpoints (the
# single-entry "view source" read stays public + rate-limited).
CONTENT_READ_KEY=
# URL the feed editor uses to create series in the content service.
CONTENT_URL=http://127.0.0.1:8787

# ── feed ────────────────────────────────────────────────────────────────
FEED_PORT=8788
# SQLite — posts and admin sessions.
FEED_DB_PATH=data/feed.sqlite
# API key for the feed JSON write endpoints. Empty disables writes.
FEED_API_KEY=
# Optional read token: set to gate the post list (the single-post "view
# source" read stays public + rate-limited).
FEED_READ_KEY=

# ── apex ────────────────────────────────────────────────────────────────
# apex is a stateless embedded static site — just a port (plus pulse's DB).
APEX_PORT=8790
APEX_DB_PATH=data/apex.sqlite

# ── daily ───────────────────────────────────────────────────────────────
DAILY_PORT=8792
# SQLite — the cached daily artifacts (NASA APOD photo and friends).
DAILY_DB_PATH=data/daily.sqlite
# NASA APOD API key. DEMO_KEY works but is sharply rate-limited; a free key
# from https://api.nasa.gov lifts the limit.
NASA_API_KEY=DEMO_KEY

# ── bookmarks ───────────────────────────────────────────────────────────
BOOKMARKS_PORT=8793
# SQLite — curated bookmarks and admin sessions.
BOOKMARKS_DB_PATH=data/bookmarks.sqlite
# Optional API key for the JSON write endpoints. Empty disables writes.
BOOKMARKS_API_KEY=
# Optional read token: set to gate the read endpoints.
BOOKMARKS_READ_KEY=

# ── qr ──────────────────────────────────────────────────────────────────
QR_PORT=8794
# SQLite — QR codes, proxy targets, and admin sessions.
QR_DB_PATH=data/qr.sqlite
# Optional API key for the JSON write endpoints. Empty disables writes.
QR_API_KEY=
# Optional read token: set to gate the enumerating read endpoints (scan and
# redirect stay public).
QR_READ_KEY=
# Public base URL — used to build proxy QR targets (the QR encodes
# <QR_PUBLIC_URL>/r/<id>). In production this is the public hostname.
QR_PUBLIC_URL=http://127.0.0.1:8794

# ── scrap ───────────────────────────────────────────────────────────────
SCRAP_PORT=8799
# SQLite — pastes, view tokens, and admin sessions.
SCRAP_DB_PATH=data/scrap.sqlite
# API key for the terminal paste API (POST /api/pastes). Empty disables it.
SCRAP_API_KEY=
# Public base URL — the API returns <SCRAP_PUBLIC_URL>/<id> for new pastes.
SCRAP_PUBLIC_URL=http://127.0.0.1:8799

# ── sideload ────────────────────────────────────────────────────────────
SIDELOAD_PORT=8800
# SQLite — builds, share tokens, and admin sessions.
SIDELOAD_DB_PATH=data/sideload.sqlite
# Directory for uploaded IPA blobs.
SIDELOAD_DIR=data/sideload-blobs
# API key for the build upload API. Empty disables writes.
SIDELOAD_API_KEY=
# Optional owner-device UDID pinned into every app's whitelist.
SIDELOAD_OWNER_UDID=
# Public base URL — used in install manifests; must be HTTPS for iOS.
SIDELOAD_PUBLIC_URL=http://127.0.0.1:8800

# ── pulse ───────────────────────────────────────────────────────────────
PULSE_PORT=8798
# SQLite — uptime checks and traffic rollups.
PULSE_DB_PATH=data/pulse.sqlite

# ── bard / dead-presidents ──────────────────────────────────────────────
BARD_PORT=8795
BARD_DB_PATH=data/bard.sqlite
DEAD_PRESIDENTS_PORT=8796
DEAD_PRESIDENTS_DB_PATH=data/dead-presidents.sqlite

# ── backup ──────────────────────────────────────────────────────────────
BACKUP_PORT=8791
# SQLite — the backup registry and admin sessions.
BACKUP_DB_PATH=data/backup.sqlite
