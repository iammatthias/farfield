# farfield — one environment file for the whole monorepo.
#
# Copy to .env and fill in. Every app reads the nearest .env walking up from
# its working directory, so this single file at the repo root serves them all.

# ── shared ──────────────────────────────────────────────────────────────
# Bind interface. 127.0.0.1 in dev; Docker sets 0.0.0.0 itself.
HOST=127.0.0.1
# true for HTTPS-only session cookies (production).
COOKIE_SECURE=false
# One password for every app's HTML admin UI.
PASSWORD=changeme
# Browser-facing service URLs — injected into the content/feed editors so the
# blob & series pickers can fetch directly. Public hostnames in production;
# localhost in dev.
BLOBS_PUBLIC_URL=http://127.0.0.1:8789
CONTENT_PUBLIC_URL=http://127.0.0.1:8787

# ── blobs ───────────────────────────────────────────────────────────────
BLOBS_PORT=8789
# SQLite — blob metadata index + admin sessions.
BLOBS_DB_PATH=data/blobs.sqlite
# API key for the blobs JSON write endpoints. Empty disables writes.
# Also required by the backup app to store snapshots — set a real value.
BLOBS_API_KEY=
# URL other farfield apps use to reach the blobs service.
BLOBS_URL=http://127.0.0.1:8789
# Byte store backend: "local" (a directory) or "r2" (Cloudflare R2).
BLOBS_BACKEND=local
# Local backend directory (when BLOBS_BACKEND=local).
BLOBS_DIR=data/blobs
# R2 backend credentials (when BLOBS_BACKEND=r2).
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ── content ─────────────────────────────────────────────────────────────
CONTENT_PORT=8787
# SQLite — collections, entries, and admin sessions.
CONTENT_DB_PATH=data/content.sqlite
# API key for the content JSON write endpoints. Empty disables writes.
CONTENT_API_KEY=
# URL the feed editor uses to create series in the content service.
CONTENT_URL=http://127.0.0.1:8787

# ── feed ────────────────────────────────────────────────────────────────
FEED_PORT=8788
# SQLite — posts and admin sessions.
FEED_DB_PATH=data/feed.sqlite
# API key for the feed JSON write endpoints. Empty disables writes.
FEED_API_KEY=

# ── apex ────────────────────────────────────────────────────────────────
# apex is a stateless embedded static site — just a port.
APEX_PORT=8790

# ── calendar ────────────────────────────────────────────────────────────
CALENDAR_PORT=8792
# SQLite — the cached daily photo calendar (NASA APOD + the UFO source).
CALENDAR_DB_PATH=data/calendar.sqlite
# NASA APOD API key. DEMO_KEY works but is sharply rate-limited; a free key
# from https://api.nasa.gov lifts the limit.
NASA_API_KEY=DEMO_KEY

# ── backup ──────────────────────────────────────────────────────────────
BACKUP_PORT=8791
# SQLite — the backup registry and admin sessions.
BACKUP_DB_PATH=data/backup.sqlite
