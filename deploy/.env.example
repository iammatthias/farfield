# Copy to deploy/.env — docker-compose reads it.
#
# The bearer token for write operations. Generate a strong one:
#   openssl rand -hex 32
FARFIELD_TOKEN=change-me

# Blob backend: "local" (default — a Docker volume) or "r2" (Cloudflare R2).
# The R2_* values below are only read when the backend is "r2".
FARFIELD_BLOBS_BACKEND=local
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
